{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.regexp.exec.js\";\nimport \"core-js/modules/es.string.replace.js\";\nimport { clearTokens } from \"../utils/storage\";\nexport default {\n  name: \"AppLayout\",\n  data: function data() {\n    return {\n      titleMap: {\n        \"/dashboard\": \"运营看板\",\n        \"/vehicles\": \"车辆管理\",\n        \"/customers\": \"客户管理\",\n        \"/orders\": \"订单管理\",\n        \"/banners\": \"广告位管理\"\n      }\n    };\n  },\n  methods: {\n    handleSelect: function handleSelect(index) {\n      this.$router.push(index);\n    },\n    logout: function logout() {\n      clearTokens();\n      this.$router.replace(\"/login\");\n    }\n  }\n};","map":{"version":3,"names":["clearTokens","name","data","titleMap","methods","handleSelect","index","$router","push","logout","replace"],"sources":["src/layout/AppLayout.vue"],"sourcesContent":["<template>\n  <div class=\"layout-shell\">\n    <aside class=\"layout-sidebar\">\n      <div class=\"brand\">\n        <div class=\"brand-mark\">CR</div>\n        <div>\n          <div class=\"brand-title\">汽车租赁平台</div>\n          <div class=\"brand-sub\">Car Rental Admin</div>\n        </div>\n      </div>\n\n      <el-menu\n        :default-active=\"$route.path\"\n        background-color=\"transparent\"\n        text-color=\"#d6e4ef\"\n        active-text-color=\"#ffffff\"\n        @select=\"handleSelect\"\n      >\n        <el-menu-item index=\"/dashboard\">首页概览</el-menu-item>\n        <el-menu-item index=\"/vehicles\">车辆管理</el-menu-item>\n        <el-menu-item index=\"/customers\">客户管理</el-menu-item>\n        <el-menu-item index=\"/orders\">订单管理</el-menu-item>\n        <el-menu-item index=\"/banners\">广告位管理</el-menu-item>\n      </el-menu>\n    </aside>\n\n    <main class=\"layout-main\">\n      <header class=\"layout-header\">\n        <div>\n          <div class=\"header-title\">{{ titleMap[$route.path] || \"管理后台\" }}</div>\n          <div class=\"header-subtitle\">覆盖车辆、客户、订单与首页广告位全生命周期管理</div>\n        </div>\n        <el-button type=\"danger\" plain @click=\"logout\">退出登录</el-button>\n      </header>\n\n      <transition name=\"fade-rise\" mode=\"out-in\">\n        <router-view />\n      </transition>\n    </main>\n  </div>\n</template>\n\n<script>\nimport { clearTokens } from \"../utils/storage\";\n\nexport default {\n  name: \"AppLayout\",\n  data() {\n    return {\n      titleMap: {\n        \"/dashboard\": \"运营看板\",\n        \"/vehicles\": \"车辆管理\",\n        \"/customers\": \"客户管理\",\n        \"/orders\": \"订单管理\",\n        \"/banners\": \"广告位管理\"\n      }\n    };\n  },\n  methods: {\n    handleSelect(index) {\n      this.$router.push(index);\n    },\n    logout() {\n      clearTokens();\n      this.$router.replace(\"/login\");\n    }\n  }\n};\n</script>\n\n<style scoped>\n.layout-shell {\n  min-height: 100vh;\n  display: grid;\n  grid-template-columns: 260px 1fr;\n}\n\n.layout-sidebar {\n  padding: 28px 20px;\n  background:\n    linear-gradient(180deg, rgba(10, 38, 58, 0.96), rgba(13, 90, 91, 0.94)),\n    linear-gradient(135deg, #0f172a, #0f766e);\n  color: #fff;\n}\n\n.brand {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 28px;\n}\n\n.brand-mark {\n  width: 46px;\n  height: 46px;\n  border-radius: 14px;\n  display: grid;\n  place-items: center;\n  font-weight: 800;\n  background: linear-gradient(135deg, #f59e0b, #f97316);\n  color: #fff;\n}\n\n.brand-title {\n  font-size: 18px;\n  font-weight: 700;\n}\n\n.brand-sub {\n  margin-top: 4px;\n  font-size: 12px;\n  color: rgba(214, 228, 239, 0.75);\n}\n\n.layout-main {\n  padding: 24px;\n}\n\n.layout-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 22px;\n}\n\n.header-title {\n  font-size: 28px;\n  font-weight: 800;\n}\n\n.header-subtitle {\n  margin-top: 6px;\n  color: var(--text-regular);\n}\n\n::v-deep .el-menu {\n  border-right: none;\n}\n\n::v-deep .el-menu-item {\n  height: 48px;\n  line-height: 48px;\n  border-radius: 12px;\n  margin-bottom: 10px;\n}\n\n::v-deep .el-menu-item.is-active {\n  background: rgba(255, 255, 255, 0.12) !important;\n}\n\n@media (max-width: 960px) {\n  .layout-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .layout-sidebar {\n    padding-bottom: 8px;\n  }\n}\n</style>\n"],"mappings":";;;AA2CA,SAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;QACA;QACA;QACA;QACA;QACA;MACA;IACA;EACA;EACAC,OAAA;IACAC,YAAA,WAAAA,aAAAC,KAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,CAAAF,KAAA;IACA;IACAG,MAAA,WAAAA,OAAA;MACAT,WAAA;MACA,KAAAO,OAAA,CAAAG,OAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}