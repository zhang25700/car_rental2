{"ast":null,"code":"import _regenerator from \"D:/code/java/car-rental/web/node_modules/@babel/runtime/helpers/esm/regenerator.js\";\nimport _slicedToArray from \"D:/code/java/car-rental/web/node_modules/@babel/runtime/helpers/esm/slicedToArray.js\";\nimport _asyncToGenerator from \"D:/code/java/car-rental/web/node_modules/@babel/runtime/helpers/esm/asyncToGenerator.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport \"core-js/modules/es.string.iterator.js\";\nimport \"core-js/modules/web.dom-collections.iterator.js\";\nimport { getActiveBanners } from \"../api/banner\";\nimport { getHotVehicles } from \"../api/vehicle\";\nexport default {\n  name: \"UserHomePage\",\n  data: function data() {\n    return {\n      hotVehicles: [],\n      banners: [],\n      imageErrors: {}\n    };\n  },\n  created: function created() {\n    var _this = this;\n    return _asyncToGenerator(/*#__PURE__*/_regenerator().m(function _callee() {\n      var _yield$Promise$all, _yield$Promise$all2, vehicleRes, bannerRes;\n      return _regenerator().w(function (_context) {\n        while (1) switch (_context.n) {\n          case 0:\n            _context.n = 1;\n            return Promise.all([getHotVehicles(), getActiveBanners()]);\n          case 1:\n            _yield$Promise$all = _context.v;\n            _yield$Promise$all2 = _slicedToArray(_yield$Promise$all, 2);\n            vehicleRes = _yield$Promise$all2[0];\n            bannerRes = _yield$Promise$all2[1];\n            _this.hotVehicles = vehicleRes.data || [];\n            _this.banners = bannerRes.data || [];\n          case 2:\n            return _context.a(2);\n        }\n      }, _callee);\n    }))();\n  },\n  methods: {\n    statusText: function statusText(status) {\n      return {\n        AVAILABLE: \"可租赁\",\n        RENTED: \"租赁中\",\n        MAINTENANCE: \"维护中\"\n      }[status] || status;\n    },\n    markImageError: function markImageError(id) {\n      this.$set(this.imageErrors, id, true);\n    }\n  }\n};","map":{"version":3,"names":["getActiveBanners","getHotVehicles","name","data","hotVehicles","banners","imageErrors","created","_this","_asyncToGenerator","_regenerator","m","_callee","_yield$Promise$all","_yield$Promise$all2","vehicleRes","bannerRes","w","_context","n","Promise","all","v","_slicedToArray","a","methods","statusText","status","AVAILABLE","RENTED","MAINTENANCE","markImageError","id","$set"],"sources":["src/views/UserHomePage.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"page-card user-hero\">\n      <div>\n        <div class=\"hero-kicker\">欢迎使用</div>\n        <h2>在线查看可租车辆和首页优惠活动</h2>\n        <p>首页广告位采用轮播展示，用户进入后可以先浏览活动，再查看可租车辆并提交订单。</p>\n      </div>\n      <el-button type=\"primary\" @click=\"$router.push('/user/vehicles')\">查看车辆</el-button>\n    </div>\n\n    <div class=\"page-card banner-panel\">\n      <h3 class=\"section-title\">首页广告</h3>\n      <el-carousel v-if=\"banners.length\" height=\"320px\" indicator-position=\"outside\">\n        <el-carousel-item v-for=\"item in banners\" :key=\"item.id\">\n          <div class=\"banner-slide\">\n            <img\n              v-if=\"item.imageUrl && !imageErrors[item.id]\"\n              :src=\"item.imageUrl\"\n              :alt=\"item.title\"\n              class=\"banner-image\"\n              @error=\"markImageError(item.id)\"\n            />\n            <div v-else class=\"banner-fallback\">\n              <div class=\"banner-fallback-title\">{{ item.title }}</div>\n            </div>\n            <div class=\"banner-overlay\">\n              <div class=\"banner-label\">首页广告位</div>\n              <div class=\"banner-title\">{{ item.title }}</div>\n            </div>\n          </div>\n        </el-carousel-item>\n      </el-carousel>\n      <div v-else class=\"banner-empty\">暂无活动内容</div>\n    </div>\n\n    <div class=\"page-card\">\n      <h3 class=\"section-title\">热门车辆</h3>\n      <el-table :data=\"hotVehicles\">\n        <el-table-column prop=\"brand\" label=\"品牌\" />\n        <el-table-column prop=\"model\" label=\"型号\" />\n        <el-table-column prop=\"dailyPrice\" label=\"日租金\" />\n        <el-table-column label=\"状态\">\n          <template slot-scope=\"{ row }\">{{ statusText(row.status) }}</template>\n        </el-table-column>\n      </el-table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getActiveBanners } from \"../api/banner\";\nimport { getHotVehicles } from \"../api/vehicle\";\n\nexport default {\n  name: \"UserHomePage\",\n  data() {\n    return {\n      hotVehicles: [],\n      banners: [],\n      imageErrors: {}\n    };\n  },\n  async created() {\n    const [vehicleRes, bannerRes] = await Promise.all([getHotVehicles(), getActiveBanners()]);\n    this.hotVehicles = vehicleRes.data || [];\n    this.banners = bannerRes.data || [];\n  },\n  methods: {\n    statusText(status) {\n      return { AVAILABLE: \"可租赁\", RENTED: \"租赁中\", MAINTENANCE: \"维护中\" }[status] || status;\n    },\n    markImageError(id) {\n      this.$set(this.imageErrors, id, true);\n    }\n  }\n};\n</script>\n\n<style scoped>\n.user-hero {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n  background: linear-gradient(135deg, rgba(15, 118, 110, 0.92), rgba(23, 50, 77, 0.95));\n  color: #fff;\n}\n\n.hero-kicker {\n  display: inline-block;\n  padding: 6px 12px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.12);\n  margin-bottom: 12px;\n}\n\n.user-hero h2 {\n  margin: 0 0 12px;\n  font-size: 30px;\n}\n\n.banner-panel {\n  margin-bottom: 20px;\n}\n\n.banner-slide {\n  position: relative;\n  height: 320px;\n  overflow: hidden;\n  border-radius: 20px;\n}\n\n.banner-image {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n.banner-fallback {\n  width: 100%;\n  height: 100%;\n  display: grid;\n  place-items: center;\n  background: linear-gradient(135deg, #ffe7bd, #fbd2d4);\n}\n\n.banner-fallback-title {\n  padding: 20px;\n  text-align: center;\n  font-size: 32px;\n  font-weight: 800;\n  color: #7c3f00;\n}\n\n.banner-overlay {\n  position: absolute;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  padding: 24px;\n  color: #fff;\n  background: linear-gradient(180deg, transparent, rgba(15, 23, 42, 0.8));\n}\n\n.banner-label {\n  display: inline-block;\n  padding: 6px 12px;\n  margin-bottom: 10px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.12);\n}\n\n.banner-title {\n  font-size: 28px;\n  font-weight: 800;\n}\n\n.banner-empty {\n  height: 180px;\n  display: grid;\n  place-items: center;\n  color: var(--text-regular);\n  border: 1px dashed var(--border-soft);\n  border-radius: 18px;\n}\n\n@media (max-width: 960px) {\n  .user-hero {\n    display: grid;\n    gap: 14px;\n  }\n\n  .banner-slide {\n    height: 240px;\n  }\n\n  .banner-title {\n    font-size: 22px;\n  }\n}\n</style>\n"],"mappings":";;;;;;AAmDA,SAAAA,gBAAA;AACA,SAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,WAAA;MACAC,OAAA;MACAC,WAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IAAA,IAAAC,KAAA;IAAA,OAAAC,iBAAA,cAAAC,YAAA,GAAAC,CAAA,UAAAC,QAAA;MAAA,IAAAC,kBAAA,EAAAC,mBAAA,EAAAC,UAAA,EAAAC,SAAA;MAAA,OAAAN,YAAA,GAAAO,CAAA,WAAAC,QAAA;QAAA,kBAAAA,QAAA,CAAAC,CAAA;UAAA;YAAAD,QAAA,CAAAC,CAAA;YAAA,OACAC,OAAA,CAAAC,GAAA,EAAApB,cAAA,IAAAD,gBAAA;UAAA;YAAAa,kBAAA,GAAAK,QAAA,CAAAI,CAAA;YAAAR,mBAAA,GAAAS,cAAA,CAAAV,kBAAA;YAAAE,UAAA,GAAAD,mBAAA;YAAAE,SAAA,GAAAF,mBAAA;YACAN,KAAA,CAAAJ,WAAA,GAAAW,UAAA,CAAAZ,IAAA;YACAK,KAAA,CAAAH,OAAA,GAAAW,SAAA,CAAAb,IAAA;UAAA;YAAA,OAAAe,QAAA,CAAAM,CAAA;QAAA;MAAA,GAAAZ,OAAA;IAAA;EACA;EACAa,OAAA;IACAC,UAAA,WAAAA,WAAAC,MAAA;MACA;QAAAC,SAAA;QAAAC,MAAA;QAAAC,WAAA;MAAA,EAAAH,MAAA,KAAAA,MAAA;IACA;IACAI,cAAA,WAAAA,eAAAC,EAAA;MACA,KAAAC,IAAA,MAAA3B,WAAA,EAAA0B,EAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}